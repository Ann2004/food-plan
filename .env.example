# ── Django core ──────────────────────────────────────────
# Required. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-50-char-string

# Set to True only in local development. NEVER enable in production.
DEBUG=False

# Comma-separated list of hosts this site can serve.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated trusted origins for CSRF (e.g. https://mydomain.com)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── Database ─────────────────────────────────────────────
# PostgreSQL example: postgres://user:password@localhost:5432/foodplan
DATABASE_URL=sqlite:///db.sqlite3

# ── Email ────────────────────────────────────────────────
# Options:
#   django.core.mail.backends.console.EmailBackend  — dev (default)
#   django.core.mail.backends.smtp.EmailBackend     — production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ── MinIO / S3 object storage ───────────────────────────
# Enabled by default. Set to False for local development without MinIO.
# When enabled, ENDPOINT, ACCESS_KEY, SECRET_KEY, and BUCKET_NAME are required.
USE_MINIO=True
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=foodplan
MINIO_USE_SSL=True

# ── Yookassa payments ───────────────────────────────────
# Required in production (DEBUG=False). Optional in development.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Logging ─────────────────────────────────────────────
# Directory for log files. Defaults to <project>/logs/
LOG_DIR=
